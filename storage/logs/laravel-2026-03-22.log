      \"<span class=sf-dump-key>img</span>\" => \"<span class=sf-dump-str title=\"86 characters\">https://res.cloudinary.com/dsxq23pin/image/upload/v1774102514/hpiqjhwa4zfgqzjysaza.jpg</span>\"
