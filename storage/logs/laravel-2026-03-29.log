    </samp>]
    \"<span class=sf-dump-key>brand</span>\" => <span class=sf-dump-note>array:6</span> [<samp data-depth=3 class=sf-dump-compact>
      \"<span class=sf-dump-key>id</span>\" => <span class=sf-dump-num>4</span>
      \"<span class=sf-dump-key>title</span>\" => \"<span class=sf-dump-str title=\"7 characters\">Hisense</span>\"
      \"<span class=sf-dump-key>slug</span>\" => \"<span class=sf-dump-str title=\"7 characters\">hisense</span>\"
      \"<span class=sf-dump-key>img</span>\" => \"<span class=sf-dump-str title=\"86 characters\">https://res.cloudinary.com/dsxq23pin/image/upload/v1774369439/li01yafdllguz1ujdwlu.png</span>\"
      \"<span class=sf-dump-key>product_count</span>\" => <span class=sf-dump-num>1</span>
      \"<span class=sf-dump-key>date</span>\" => \"<span class=sf-dump-str title=\"16 characters\">24th March, 2026</span>\"
