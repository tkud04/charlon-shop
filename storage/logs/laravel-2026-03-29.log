      \"<span class=sf-dump-key>img</span>\" => \"<span class=sf-dump-str title=\"86 characters\">https://res.cloudinary.com/dsxq23pin/image/upload/v1774106648/wflj8hhpyukajn9ugc10.png</span>\"
      \"<span class=sf-dump-key>product_count</span>\" => <span class=sf-dump-num>2</span>
      \"<span class=sf-dump-key>date</span>\" => \"<span class=sf-dump-str title=\"16 characters\">21st March, 2026</span>\"
